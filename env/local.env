# Local developer stack — real API on localhost (pairs with API INVERSORA_ENV=local).
EXPO_PUBLIC_APP_ENV=local
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_NEWS_API_ENABLED=false

