# API base URL for the Inversora backend.
# Restart Expo (Metro) after changing this value.
#
# Quick help: npm run api:url
#
# Platform notes:
# - iOS Simulator:     http://localhost:3000
# - Android Emulator:  http://10.0.2.2:3000
# - Physical device:   http://<your-lan-ip>:3000  (npm run api:url -- --lan)
# - Expo web:          http://localhost:3000       (API must allow CORS for :8081)
# - Staging (Railway): https://your-service.railway.app
EXPO_PUBLIC_API_URL=http://localhost:3000
