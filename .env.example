# Inversora mobile — environment profile
# Restart Expo (Metro) after changing any EXPO_PUBLIC_* value.
#
# Profiles:
#   local — developer machine, real API (EXPO_PUBLIC_API_URL), mock fallback on errors
#   ei    — entorno integrado, 100% local mocks (no backend required)
#   qa    — QA/staging API, real data, no mock fallback, debug-friendly builds
#   pro   — production API, release builds (minified via EAS), no mock fallback
#
EXPO_PUBLIC_APP_ENV=local

# API base URL (ignored in `ei` mode)
# Quick help: npm run api:url
EXPO_PUBLIC_API_URL=http://localhost:3000

# Set to `true` only when the target API exposes `GET /news` (BFF module deployed).
# While unset or `false`, the home news section uses bundled educational headlines.
# EXPO_PUBLIC_NEWS_API_ENABLED=true
