# Inversora mobile — environment profile
# Restart Expo (Metro) after changing EXPO_PUBLIC_* values.
#
# Selector (same name as inversora-api): INVERSORA_ENV → EXPO_PUBLIC_APP_ENV
# Priority: INVERSORA_ENV → EXPO_PUBLIC_APP_ENV → APP_ENV → ENV
#
# Profiles (committed defaults in env/*.env):
#   local — API local (EXPO_PUBLIC_API_URL), mock fallback si la API falla
#   qa    — staging API, sin mock fallback
#   pro   — production API, release builds
#
# Stack local con datos productivos (sin depender de QA/Neon):
#   API:  npm run start:pro   (inversora-api → BD prod + FMP live)
#   App:  npm run start:local → http://localhost:3000
#
# Solo app contra producción:
#   npm run start:pro
#
# Quick API URL help: npm run api:url [-- --ios|--android|--lan]
INVERSORA_ENV=local

# Optional debug when starting Expo:
# INVERSORA_ENV_DEBUG=true

# Personal overrides for QA/Pro URLs live in `.env.qa` / `.env.pro` (gitignored).
#
# Security: never put secrets behind EXPO_PUBLIC_*.
# EXPO_PUBLIC_SSL_PINNING_ENABLED=true   # native pro builds only
# EXPO_PUBLIC_BRANDFETCH_CLIENT_ID=your-brandfetch-client-id
# EXPO_PUBLIC_PRIVACY_POLICY_URL=https://inversora--inversora.expo.app/privacidad.html
