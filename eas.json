{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_APP_ENV": "local"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_APP_ENV": "qa"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_APP_ENV": "pro"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
