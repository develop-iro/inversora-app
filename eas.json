{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "22.14.0",
      "env": {
        "EXPO_PUBLIC_APP_ENV": "local"
      }
    },
    "development-simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "22.14.0",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_APP_ENV": "local"
      }
    },
    "preview": {
      "distribution": "internal",
      "node": "22.14.0",
      "env": {
        "EXPO_PUBLIC_APP_ENV": "qa",
        "EXPO_PUBLIC_API_URL": "https://inversora-api-production.up.railway.app",
        "EXPO_PUBLIC_NEWS_API_ENABLED": "false",
        "NODE_ENV": "production"
      }
    },
    "production": {
      "node": "22.14.0",
      "env": {
        "EXPO_PUBLIC_APP_ENV": "pro",
        "EXPO_PUBLIC_API_URL": "https://inversora-api-production.up.railway.app",
        "EXPO_PUBLIC_NEWS_API_ENABLED": "false",
        "EXPO_PUBLIC_SSL_PINNING_ENABLED": "true",
        "NODE_ENV": "production"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
