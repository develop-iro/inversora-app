{
  "name": "inversora",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "author": "Ivan Romero",
  "license": "SEE LICENSE IN LICENSE.md",
  "dependencies": {
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo-google-fonts/nunito": "^0.4.2",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@sentry/react-native": "~8.19.0",
    "babel-preset-expo": "~57.0.2",
    "expo": "~57.0.4",
    "expo-blur": "~57.0.0",
    "expo-build-properties": "~57.0.3",
    "expo-clipboard": "~57.0.0",
    "expo-constants": "~57.0.3",
    "expo-file-system": "~57.0.0",
    "expo-font": "^57.0.0",
    "expo-linear-gradient": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-router": "~57.0.4",
    "expo-secure-store": "~57.0.0",
    "expo-sharing": "~57.0.3",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "nativewind": "^4.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-css-interop": "0.2.6",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "^15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "tailwindcss": "^3.4.17",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@playwright/test": "^1.61.1",
    "@types/react": "~19.2.17",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~57.0.0",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-react-native-a11y": "^3.5.1",
    "expo-mcp": "~0.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tsx": "^4.20.3",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "node scripts/run-expo-env.mjs local start",
    "start:local": "node scripts/run-expo-env.mjs local start",
    "start:qa": "node scripts/run-expo-env.mjs qa start",
    "start:pro": "node scripts/run-expo-env.mjs pro start",
    "start:mcp": "node scripts/run-expo-env.mjs local start --mcp",
    "start:mcp:qa": "node scripts/run-expo-env.mjs qa start --mcp",
    "android:local": "node scripts/run-expo-env.mjs local start --android",
    "android": "node scripts/run-expo-env.mjs local start --android",
    "ios:local": "node scripts/run-expo-env.mjs local start --ios",
    "ios": "node scripts/run-expo-env.mjs local start --ios",
    "web": "node scripts/run-expo-env.mjs local start --web",
    "api:url": "node scripts/print-api-url.mjs",
    "generate:global-css": "node scripts/generate-global-css.mjs",
    "generate:tailwind": "node scripts/generate-tailwind-config.mjs",
    "generate:theme": "node scripts/generate-global-css.mjs && node scripts/generate-tailwind-config.mjs",
    "test:env": "node --test scripts/load-env.spec.mjs",
    "test:theme": "node --test scripts/generate-global-css.spec.mjs scripts/generate-tailwind-config.spec.mjs",
    "test:scripts": "pnpm run test:env && pnpm run test:theme",
    "test:unit": "bash -c 'shopt -s globstar nullglob && npx tsx --test test/domain/**/*.spec.ts test/application/**/*.spec.ts test/contracts/**/*.spec.ts'",
    "e2e:install": "playwright install --with-deps chromium",
    "e2e:web:serve": "node scripts/run-expo-env.mjs local start --web",
    "test:e2e": "playwright test",
    "security:verify-plugins": "npx expo config --type public",
    "lint": "expo lint",
    "lint:ci": "expo lint --max-warnings 0",
    "lint:fix": "expo lint --fix",
    "typecheck": "tsc --noEmit",
    "test:ci": "pnpm run typecheck && pnpm run lint:ci && pnpm run test:unit && pnpm run test:scripts && pnpm run security:verify-plugins && pnpm run test:e2e",
    "audit:prod": "node scripts/audit-prod.mjs",
    "quality": "pnpm run test:ci",
    "build:web:ci": "node scripts/run-expo-env.mjs qa export --platform android",
    "build:web:pro": "node scripts/run-expo-env.mjs pro export --platform web --clear",
    "deploy:web:pro": "pnpm run generate:theme && pnpm run build:web:pro && pnpm dlx eas-cli deploy --alias inversora",
    "verify:prebuild": "node scripts/run-expo-env.mjs pro prebuild --no-install",
    "build:preview": "npx eas-cli build --profile preview",
    "build:preview:android": "npx eas-cli build --platform android --profile preview",
    "build:preview:ios": "npx eas-cli build --platform ios --profile preview",
    "build:production:ios": "npx eas-cli build --platform ios --profile production-internal",
    "build:production:android": "npx eas-cli build --platform android --profile production-internal",
    "build:development": "npx eas-cli build --profile development",
    "build:development:android": "npx eas-cli build --platform android --profile development",
    "build:development:ios": "npx eas-cli build --platform ios --profile development",
    "build:development:ios-simulator": "npx eas-cli build --platform ios --profile development-simulator",
    "eas:login": "npx eas-cli login",
    "eas:init": "npx eas-cli init",
    "eas-build-post-install": "pnpm run generate:theme",
    "prepare": "node scripts/prepare-husky.cjs"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs}": [
      "eslint --fix"
    ]
  },
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "pnpm": {
    "overrides": {
      "xcode>uuid": "^11.1.1",
      "@expo/xcpretty>js-yaml": "^4.2.0",
      "@eslint/eslintrc>js-yaml": "^4.2.0"
    }
  }
}
